# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# JWT signing key — REQUIRED. App fails to start if unset, empty, or
# shorter than 32 characters. Use a high-entropy value, never the
# placeholder below.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-me-with-a-real-high-entropy-secret-at-least-32-chars

# Fernet encryption key for credential storage at rest. REQUIRED. App
# fails to start if the value isn't a valid urlsafe-base64-encoded
# 32-byte Fernet key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Oracle XE (optional profile)
# ORACLE_PASSWORD=oracle
