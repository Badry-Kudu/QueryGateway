# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# JWT signing key — MUST be changed in production
JWT_SECRET_KEY=changeme-use-a-real-secret-in-production

# Fernet encryption key for credential storage at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=changeme-generate-a-real-fernet-key

# Oracle XE (optional profile)
# ORACLE_PASSWORD=oracle
