FROM python:3.14-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install system dependencies required for psycopg2, bcrypt, and healthcheck
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install core Python dependencies from the hash-pinned lockfile.
# --require-hashes aborts the build if any downloaded artifact's hash does not
# match the committed lockfile, blocking tampered/substituted packages (§4.9).
# requirements.lock is generated from requirements.txt via
# `uv pip compile --generate-hashes` and committed alongside it.
COPY backend/requirements.txt backend/requirements.lock backend/requirements-oracle.txt ./
RUN pip install --no-cache-dir --require-hashes -r requirements.lock
# Oracle driver is optional — best-effort; app still starts without it.
RUN pip install --no-cache-dir -r requirements-oracle.txt || \
    echo "WARNING: python-oracledb not available; Oracle connectivity tests will fail at runtime."

# Copy application code
COPY backend/ .

# Non-root user for security
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser
USER appuser

EXPOSE 8000

# --proxy-headers makes uvicorn read X-Forwarded-For/X-Real-IP so the real
# client IP (not the proxy's container IP) reaches the access log and
# structured logs. Crucially we do NOT hardcode --forwarded-allow-ips here:
# the trusted source is supplied per-deployment via the FORWARDED_ALLOW_IPS
# env var (uvicorn honors it), and docker-compose.yml scopes it to the
# dedicated nginx<->api "edge" subnet. That way only the reverse proxy's hop
# is trusted — sibling containers (db, oracle) sit on a separate network and
# cannot reach this service to forge headers. If FORWARDED_ALLOW_IPS is unset
# uvicorn falls back to the safe default (127.0.0.1), so a bare `docker run`
# never trusts arbitrary peers. Defense in depth: the backend is not
# published to the host (compose uses `expose`), and nginx OVERWRITES
# X-Forwarded-For with the real client address (see docker/nginx.conf).
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", \
     "--proxy-headers"]
