# Copy this file to .env on the production host and fill in real values.
# Never commit the real .env file.

# Compose project name. Keep this stable so Docker volumes and networks have
# predictable names across deployments.
COMPOSE_PROJECT_NAME=querygateway

# PostgreSQL application database. Use a strong unique password.
POSTGRES_DB=querygateway
POSTGRES_USER=querygateway_app
POSTGRES_PASSWORD=replace-with-strong-db-password

# The API connects to Postgres through the private Docker network.
DATABASE_URL=postgresql+asyncpg://querygateway_app:replace-with-strong-db-password@db:5432/querygateway

# Application runtime.
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
CORS_ORIGINS=https://querygateway.example.com
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
QUERY_TIMEOUT_SECONDS=30

# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-generated-secret

# Fernet key for encrypted credentials. Back this up securely; losing it makes
# saved Oracle credentials unrecoverable.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-generated-fernet-key

# Seeded admin account. Store only the bcrypt hash, never the plaintext
# password.
# Generate inside the backend environment with:
#   python -c "from app.auth.hashing import hash_password; print(hash_password('your-password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Required only when Oracle thick mode is used.
ORACLE_CLIENT_LIB_DIR=

# Public HTTP port for the nginx frontend container. Prefer TLS in production
# through an ALB, reverse proxy, or a TLS-enabled edge container.
PUBLIC_HTTP_PORT=80

# Optional Oracle XE profile password if the local oracle service is enabled.
# ORACLE_PASSWORD=replace-with-strong-oracle-password
